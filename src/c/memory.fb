mod std::c;

#[extern]
pub func malloc(size: u64) mut *void;

#[extern]
pub func free(ptr: *void);

#[extern]
pub func memcpy(dst: mut *void, src: *void, size: u64) mut *void;

#[extern]
pub func memmove(dst: mut *void, src: *void, size: u64) mut *void;

#[extern]
pub func memset(dst: mut *void, ch: i32, size: u64) mut *void;

#[extern]
pub func memcmp(lhs: *void, rhs: *void, size: u64) i32;
