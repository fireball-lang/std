mod std::net;

import std::net::unix;

pub struct Socket {
    pub ip: [4]u8,
    pub port: u16,

    fd: i32,
}

impl Socket {
    pub func connect(ip: [4]u8, port: u16) Self {
        var address = unix::SocketAddress::new(unix::Domain::IP4, ip, port);

        var fd = unix::socket(unix::Domain::IP4, unix::Type::TCP, unix::Protocol::IP);
        unix::connect(fd, &address, sizeof(unix::SocketAddress));

        return Self {
            ip: ip,
            port: port,
            fd: fd,
        };
    }

    pub func listen(ip: [4]u8, port: u16) Self {
        var address = unix::SocketAddress::new(unix::Domain::IP4, ip, port);

        var fd = unix::socket(unix::Domain::IP4, unix::Type::TCP, unix::Protocol::IP);
        unix::bind(fd, &address, sizeof(unix::SocketAddress));
        unix::listen(fd, 64);

        return Self {
            ip: ip,
            port: port,
            fd: fd,
        };
    }

    pub func accept(self) Self {
        var address: unix::SocketAddress;
        var address_len = sizeof(unix::SocketAddress);

        var fd = unix::accept(self.fd, &address, &address_len);

        return Self {
            ip: address.ip,
            port: address.port(),
            fd: fd,
        };
    }

    pub func send(self, data: *void, size: u64) u64 {
        return unix::send(self.fd, data, size, 0) as u64;
    }

    pub func receive(self, buffer: mut* void, size: u64) u64 {
        return unix::recv(self.fd, buffer, size, 0) as u64;
    }

    pub func close(self) {
        unix::close(self.fd);
    }
}
